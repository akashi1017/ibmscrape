# Backend environment variables (copy to backend/.env for local dev)
DATABASE_URL=postgresql://digituser:digitpass@localhost:5432/digitdb
SECRET_KEY=your-secret-key-here-change-in-production
ACCESS_TOKEN_EXPIRE_MINUTES=60

# HuggingFace model URLs (used to download model at startup if not present locally)
HF_MODEL_URL=https://huggingface.co/akashi1017/digit-classification-mnist/resolve/main/best_mnist_cnn.keras
HF_FALLBACK_URL=https://huggingface.co/akashi1017/digit-classification-mnist/resolve/main/best_model.pb
HF_RESNET_MODEL_URL=https://huggingface.co/akashi1017/digit-classification-mnist/resolve/main/resnet_mnist_digits.hdf5

# Frontend environment variables (set in Vercel dashboard for production)
# VITE_API_URL=https://your-backend.onrender.com

# Groq Vision LLM (used for uploaded photos — handles ruled paper, forms, cheques)
# Free tier: 30 RPM, ~14k req/day. Get a key at: https://console.groq.com/keys
USE_VISION_API=true
GROQ_API_KEY=your_groq_api_key_here
GROQ_VISION_MODEL=meta-llama/llama-4-scout-17b-16e-instruct
